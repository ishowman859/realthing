{
  "expo": {
    "name": "Verity",
    "slug": "verity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F2F4F6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.verity.app",
      "infoPlist": {
        "NSCameraUsageDescription": "사진 촬영 후 pHash를 블록체인에 등록하기 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "촬영한 사진을 저장하기 위해 사진 라이브러리 접근이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F2F4F6"
      },
      "package": "com.verity.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "사진 촬영 후 pHash를 블록체인에 등록하기 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "검증할 사진과 영상을 선택하기 위해 앨범 접근이 필요합니다."
        }
      ],
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "검증 해시가 표시된 촬영본을 사진 보관함에 저장합니다.",
          "savePhotosPermission": "검증 해시가 표시된 촬영본을 사진 보관함에 저장합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "verityApiUrl": "http://98.84.127.220:4000",
      "verityOwnerAddress": "demo-owner"
    }
  }
}
