PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verity

# Optional: enable S3 upload for multipart file requests
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Public verification base URL used by API responses
VERIFY_BASE_URL=https://verify.verity.app/v

# Optional CORS origin (comma separated)
CORS_ORIGIN=*

# Optional: admin route auth token (`/admin`, `/v1/admin/*`)
ADMIN_TOKEN=

# Optional: Silent-Face-Anti-Spoofing inference API endpoint
# Expected request:  POST JSON { imageBase64: "..." }
# Expected response: JSON { spoofProbability: 0.0~1.0, model?: "Silent-Face-Anti-Spoofing" }
SILENT_FACE_API_URL=

# 배치 머클 스케줄 (선택)
# BATCH_MERKLE_FLUSH_INTERVAL_SEC=5
# BATCH_MERKLE_IMMEDIATE_AT_COUNT=50000
# BATCH_SCHEDULER_IDLE_MS=30000

# IP당 업로드(POST /v1/assets + /v1/ingest/sha256 합산) 분당 횟수
# UPLOAD_RATE_LIMIT_PER_MINUTE=3
# UPLOAD_RATE_WINDOW_MS=60000
